# OpenAI is the reasoning, copywriting, structured-output, chat, and trend-search provider.
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.6
OPENAI_REASONING_EFFORT=low

# BytePlus ModelArk is the official Seedream API provider.
# ARK_API_KEY is also accepted as a fallback variable name.
SEEDREAM_API_KEY=your_byteplus_modelark_api_key
SEEDREAM_MODEL=dola-seedream-5-0-pro-260628
SEEDREAM_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3

# Local API server. Vite proxies /api here during development.
PORT=8787
